{
  "nodeModulesDir":"auto",
  "imports": {
    "@dimforge/rapier3d-compat": "npm:@dimforge/rapier3d-compat@^0.19.3",
    "@goodpuppies/logicalassert": "jsr:@goodpuppies/logicalassert@0.1.2",
    "@mommysgoodpuppy/logchannel": "jsr:@mommysgoodpuppy/logchannel@0.1.0",
    "@std/assert": "jsr:@std/assert@1.0.13",
    "@types/three": "npm:@types/three@^0.184.0",
    "three": "npm:three@^0.184.0"
  },
  "tasks": {
    "wizard": "deno run -A --unstable-webgpu src/wizard_dungeon.ts",
    "build": "deno bundle --minify -o r3f.js r3f.tsx && deno compile -A --unstable-webgpu --include ./SDL2.dll ./r3f.js"
  }
}
